{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "K24",
  "version": "1.0.3",
  "identifier": "com.krishasales.k24",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "K24 - Business Intelligence",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://127.0.0.1:8001 ws://127.0.0.1:8001"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "externalBin": [
      "binaries/k24-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "K24 Business Intelligence Platform",
    "longDescription": "K24 - AI-powered business intelligence platform for Tally users.",
    "category": "Business",
    "publisher": "Krisha Sales"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "k24"
        ]
      }
    },
    "shell": {
      "open": true
    }
  }
}