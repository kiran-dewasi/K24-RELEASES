# K24 Desktop Backend - Local Development Environment Variables
# Copy this file to .env and update values as needed

# ===================================================================
# DEV MODE CONFIGURATION
# ===================================================================

# Enable development mode bypass for token validation
# When DEBUG=true:
# - Backend accepts X-Dev-Mode header from frontend
# - Allows testing activation flow without Tauri context
# 
# IMPORTANT: 
# - This ONLY works when running from source (not frozen exe)
# - Production builds ignore DEBUG even if set
# - Never commit .env file with DEBUG=true to production
DEBUG=true

# Enable Socket.IO server (WebSocket)
# Set to true if you need real-time communication for Remote Tally Agents.
# Default: false (prevents unnecessary server startup on desktop)
ENABLE_SOCKET_IO=false

# ===================================================================
# GOOGLE AI CONFIGURATION (Required for AI features)
# ===================================================================

# Your Google AI API key for Gemini model
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ===================================================================
# NOTES FOR PRODUCTION
# ===================================================================

# Production builds should:
# 1. Not include DEBUG variable (or set to false)
# 2. Use encrypted config for sensitive keys
# 3. Package with installer that sets proper env vars
#
# See T6_CLEANUP_SUMMARY.md for security details
